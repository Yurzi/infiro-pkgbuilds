# Maintainer: Yurzi <yurzi@foxmail.com>

pkgname=infiro-keyring
pkgver=20260529
pkgrel=2
pkgdesc='Infiro repository PGP keyring'
arch=('any')
url='https://github.com/Yurzi/infiro-pkgbuilds'
license=('GPL-3.0-or-later')
depends=('archlinux-keyring')
install="${pkgname}.install"
source=('infiro.gpg'
        'infiro-trusted'
        'infiro-revoked')
sha256sums=('37b605fdcf38ad3743856794ded301ce94c4cfe56de5b89027c147b524cef7b0'
            '6c31dfc2bba92e8bc1d24cfeccc97f5c43be6c2e4fab1c744d5edc4e344c4b85'
            'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855')

package() {
  install -Dm644 infiro.gpg     "${pkgdir}/usr/share/pacman/keyrings/infiro.gpg"
  install -Dm644 infiro-trusted "${pkgdir}/usr/share/pacman/keyrings/infiro-trusted"
  install -Dm644 infiro-revoked "${pkgdir}/usr/share/pacman/keyrings/infiro-revoked"
}

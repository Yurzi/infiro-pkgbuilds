# Maintainer: Yurzi <yurzi@foxmail.com>

pkgname=smlfmt
pkgver=1.3.0
pkgrel=1
pkgdesc="A custom formatter for Standard ML"
arch=('x86_64')
url='https://github.com/shwestrick/smlfmt'
license=('MIT')
depends=('gmp')
makedepends=('mlton')
checkdepends=('git' 'python')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/shwestrick/smlfmt/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('9d26a87bfba7d49929edf3cbdc060e9a58cd5a5b1367456281aed2e3e267926a')

build() {
  cd "$srcdir/$pkgname-$pkgver"
  make
}

check() {
  cd "$srcdir/$pkgname-$pkgver"
  # test/runall locates test dirs via the git root
  git init -q
  test/runall
}

package() {
  cd "$srcdir/$pkgname-$pkgver"
  make DESTDIR="$pkgdir" PREFIX=/usr install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

# Maintainer: Yurzi <yurzi@foxmail.com>

_extname=pgvector
pkgname=postgresql-${_extname}
pkgver=0.8.4
pkgrel=1
pkgdesc="A vector similarity search extension for PostgreSQL"
arch=('x86_64')
url='https://github.com/pgvector/pgvector'
license=('custom')
depends=('postgresql')
makedepends=('llvm' 'clang')
optdepends=()
_archive="${_extname}-${pkgver}"
source=("${_archive}.tar.gz::https://github.com/pgvector/pgvector/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('08575cd4a9d612d36dca821aa53e82c014aba8ef34c4c12d6ef6bff9f1093ef2')

build() {
  cd "$srcdir/$_archive"
  make OPTFLAGS=""
}

package() {
  cd "$srcdir/$_archive"
  make DESTDIR="$pkgdir/" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}


# Maintainer: Yurzi <yurzi@foxmail.com>

_extname=pgvector
pkgname=postgresql-${_extname}
pkgver=0.8.5
pkgrel=1
pkgdesc="A vector similarity search extension for PostgreSQL"
arch=('x86_64')
url='https://github.com/pgvector/pgvector'
license=('custom')
depends=('postgresql')
makedepends=('llvm' 'clang')
optdepends=()
_archive="${_extname}-${pkgver}"
source=("${_archive}.tar.gz::https://github.com/pgvector/pgvector/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('6f88a5cbdde31666f4b6c1a6b75c51dcbeffe58f9a7d2b26e502d5a6e5e14d44')

build() {
  cd "$srcdir/$_archive"
  make OPTFLAGS=""
}

package() {
  cd "$srcdir/$_archive"
  make DESTDIR="$pkgdir/" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}


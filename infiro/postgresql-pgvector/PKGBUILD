# Maintainer: Yurzi <yurzi@foxmail.com>

_extname=pgvector
pkgname=postgresql-${_extname}
pkgver=0.8.3
pkgrel=1
pkgdesc="A vector similarity search extension for PostgreSQL"
arch=('x86_64')
url='https://github.com/pgvector/pgvector'
license=('custom')
depends=('postgresql')
makedepends=('llvm' 'clang')
optdepends=()
_archive="${_extname}-${pkgver}"
source=("${_archive}.tar.gz::https://github.com/pgvector/pgvector/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('dc080c511a6354a1628eb19f9bc8e77ce880dde16c889744a6814c8c0006e36c')

build() {
  cd "$srcdir/$_archive"
  make OPTFLAGS=""
}

package() {
  cd "$srcdir/$_archive"
  make DESTDIR="$pkgdir/" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}


pkgname=ttf-lxgw-neo-xihei-plus
pkgver=1.303
pkgrel=2
pkgdesc="「霞鹜新晰黑＋ / LXGW Neo XiHei Plus」，在「霞鹜新晰黑」基础上补全扩展 A 区所有汉字，以使字库达到 GB 18030-2022 实现级别 2 的收字范围。"
arch=('any')
url="https://github.com/lxgw/LxgwNeoXiHei"
license=('IPA')
source=("LXGWNeoXiHeiPlus-${pkgver}.ttf::${url}/releases/download/v${pkgver}/LXGWNeoXiHeiPlus.ttf"
        "LICENSE.md"
        "LICENSE_CHS.md")
sha256sums=('fce5491042ebfce7bd23fc4afdd13ab925534bf3a4f0413fede0f2679ad83a7e'
            'bce9800ab47cd0961c2a536d5ecfb983442d58eec1db5ff88a5f1a8d1c682367'
            '0b8c1c52b89a85fed553d3e0c11bee3e9bf82407af3b9034c109ab6aad484b98')

package() {
  install -Dm644 "LXGWNeoXiHeiPlus-${pkgver}.ttf" "${pkgdir}/usr/share/fonts/TTF/LXGWNeoXiHeiPlus.ttf"
  install -Dm644 LICENSE.md     -t "${pkgdir}/usr/share/licenses/${pkgname}/"
  install -Dm644 LICENSE_CHS.md -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
